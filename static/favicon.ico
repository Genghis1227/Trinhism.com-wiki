<!DOCTYPE html>
<html lang="en" class="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script>
        (function() {
            var savedTheme = localStorage.getItem('theme') || 'dark';
            if (savedTheme === 'dark') {
                document.documentElement.classList.add('dark');
            } else {
                document.documentElement.classList.remove('dark');
            }
        })();
    </script>
    <title>Trinhism | Premium 3D Printing & Engineering Workspace</title>
    <meta name="description" content="A hub for precision 3D printing, custom engineering designs, and technical applications.">
    <link rel="apple-touch-icon" sizes="180x180" href="/assets/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/assets/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/assets/favicon-16x16.png">
    <link rel="manifest" href="/assets/site.webmanifest">
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Space Grotesk', 'Inter', 'sans-serif'],
                    },
                    colors: {
                        neon: {
                            blue: '#00f0ff',
                        },
                        dark: {
                            base: '#050505',
                            surface: '#121212',
                        }
                    }
                }
            }
        }
    </script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Space+Grotesk:wght@400;500;700&display=swap" rel="stylesheet">
    <style>
        body {
            background-color: #050505;
            color: #ffffff;
            /* Subtle glowing grid pattern */
            background-image: 
                linear-gradient(to right, rgba(0, 240, 255, 0.05) 1px, transparent 1px),
                linear-gradient(to bottom, rgba(0, 240, 255, 0.05) 1px, transparent 1px);
            background-size: 40px 40px;
            position: relative;
        }
        
        /* Soft radial gradient behind hero */
        body::before {
            content: '';
            position: absolute;
            top: 0;
            left: 50%;
            transform: translateX(-50%);
            width: 100%;
            max-width: 800px;
            height: 800px;
            background: radial-gradient(circle, rgba(0,240,255,0.08) 0%, rgba(5,5,5,0) 70%);
            pointer-events: none;
            z-index: -1;
        }
        
        .glass-card {
            background: rgba(18, 18, 18, 0.6);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.05);
            transition: all 0.3s ease;
        }
        .glass-card:hover {
            border-color: rgba(0, 240, 255, 0.3);
            box-shadow: 0 0 20px rgba(0, 240, 255, 0.1);
            transform: translateY(-4px);
        }
    </style>
    <link rel="stylesheet" href="/assets/navigation.css">
    <script src="/assets/navigation.js" defer></script>
</head>
<body class="min-h-screen flex flex-col antialiased">
    <!-- Navbar -->
    <header class="w-full border-b border-white/5 bg-dark-base/80 backdrop-blur-md sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
            <a href="/" class="text-2xl font-bold tracking-tighter text-white flex items-center gap-2">
                <img src="/assets/apple-touch-icon.png" alt="Trinhism Logo" class="w-6 h-6 rounded-sm shadow-[0_0_10px_rgba(0,240,255,0.3)] object-contain" />
                Trinhism
            </a>
            <nav class="hidden md:flex gap-8 text-sm font-medium text-gray-400">
                <a href="/shop" class="hover:text-neon-blue transition-colors">Shop</a>
                <a href="/app" class="hover:text-neon-blue transition-colors">App</a>
                <a href="/wiki/" class="hover:text-neon-blue transition-colors">Wiki</a>
            </nav>
        </div>
    </header>

    <!-- Main Content -->
    <main class="flex-grow flex flex-col items-center justify-center px-6 py-24 relative z-10">
        <!-- Hero Section -->
        <div class="max-w-6xl w-full flex flex-col md:flex-row items-center gap-12 mb-20">
            <div class="md:w-1/2 text-center md:text-left">
                <div class="inline-block mb-6 px-4 py-1.5 rounded-full border border-neon-blue/20 bg-neon-blue/5 text-neon-blue text-xs font-medium tracking-wide uppercase">
                    Precision &bull; Engineering &bull; Software
                </div>
                <h1 class="text-5xl md:text-7xl font-bold mb-6 leading-tight tracking-tight">
                    Crafting Custom Systems. <br />
                    <span class="text-transparent bg-clip-text bg-gradient-to-r from-gray-500 to-white">Brought to Light.</span>
                </h1>
                <p class="text-lg md:text-xl text-gray-400 max-w-2xl mx-auto md:mx-0 mb-10 leading-relaxed font-sans">
                    Fusing physical 3D prototyping with highly focused, clutter-free software engines designed to eliminate workflow friction and balance your daily tasks.
                </p>
            </div>
            <div class="md:w-1/2 flex justify-center">
                <div class="relative p-2 rounded-3xl bg-gradient-to-tr from-white/10 to-white/5 border border-white/10 shadow-[0_0_40px_rgba(0,240,255,0.15)] group transition-transform duration-500 hover:scale-105">
                    <div class="absolute inset-0 bg-neon-blue/20 blur-3xl opacity-50 group-hover:opacity-80 transition-opacity duration-500"></div>
                    <img src="./assets/trinhism-logo.png" alt="Trinhism Cyber Brain" class="relative z-10 w-full max-w-sm md:max-w-md rounded-2xl bg-white shadow-2xl" />
                </div>
            </div>
        </div>

        <!-- CTA Cards -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 w-full max-w-5xl">
            <!-- Shop Card -->
            <a href="/shop" class="glass-card rounded-2xl p-8 md:p-12 group block relative overflow-hidden">
                <div class="absolute top-0 right-0 p-8 opacity-10 group-hover:opacity-20 transition-opacity">
                    <svg class="w-32 h-32 text-neon-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M14 10l-2 1m0 0l-2-1m2 1v2.5M20 7l-2 1m2-1l-2-1m2 1v2.5M14 4l-2-1-2 1M4 7l2-1M4 7l2 1M4 7v2.5M12 21l-2-1m2 1l2-1m-2 1v-2.5M6 18l-2-1v-2.5M18 18l2-1v-2.5"></path></svg>
                </div>
                <div class="relative z-10">
                    <h2 class="text-3xl font-bold mb-3 text-white flex items-center gap-3">
                        Shop Showcase <span class="text-neon-blue opacity-0 group-hover:opacity-100 group-hover:translate-x-1 transition-all">&rarr;</span>
                    </h2>
                    <p class="text-gray-400 mb-6 font-sans">Explore custom 3D printed items, mechanical designs, and workshop organization creations.</p>
                    <div class="inline-flex items-center justify-center px-6 py-3 rounded-lg bg-white/5 border border-white/10 text-white text-sm font-medium group-hover:bg-neon-blue group-hover:text-black group-hover:border-neon-blue transition-colors">
                        View Catalog
                    </div>
                </div>
            </a>

            <!-- App Card -->
            <a href="/app" class="glass-card rounded-2xl p-8 md:p-12 group block relative overflow-hidden">
                <div class="absolute top-0 right-0 p-8 opacity-10 group-hover:opacity-20 transition-opacity">
                    <svg class="w-32 h-32 text-neon-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"></path></svg>
                </div>
                <div class="relative z-10">
                    <h2 class="text-3xl font-bold mb-3 text-white flex items-center gap-3">
                        Software App <span class="text-neon-blue opacity-0 group-hover:opacity-100 group-hover:translate-x-1 transition-all">&rarr;</span>
                    </h2>
                    <p class="text-gray-400 mb-6 font-sans">Discover our mobile and desktop applications built to streamline precision engineering workflows.</p>
                    <div class="inline-flex items-center justify-center px-6 py-3 rounded-lg bg-white/5 border border-white/10 text-white text-sm font-medium group-hover:bg-neon-blue group-hover:text-black group-hover:border-neon-blue transition-colors">
                        Get the App
                    </div>
                </div>
            </a>
        </div>
    </main>

    <!-- Footer -->
    <footer class="w-full py-8 border-t border-white/5 mt-auto text-center z-10 relative">
        <p class="text-gray-500 text-sm font-sans">&copy; 2026 Trinhism. All rights reserved.</p>
    </footer>
<script defer src="https://static.cloudflareinsights.com/beacon.min.js/v833ccba57c9e4d2798f2e76cebdd09a11778172276447" integrity="sha512-57MDmcccJXYtNnH+ZiBwzC4jb2rvgVCEokYN+L/nLlmO8rfYT/gIpW2A569iJ/3b+0UEasghjuZH/ma3wIs/EQ==" data-cf-beacon='{"version":"2024.11.0","token":"0de3716861a14dc0a57f5b1005d83e9a","r":1,"server_timing":{"name":{"cfCacheStatus":true,"cfEdge":true,"cfExtPri":true,"cfL4":true,"cfOrigin":true,"cfSpeedBrain":true},"location_startswith":null}}' crossorigin="anonymous"></script>
</body>
</html>
